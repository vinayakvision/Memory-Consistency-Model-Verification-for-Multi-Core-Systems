$var integer  32 +    fail_cnt  $end

$scope module u_mem $end
$var parameter 32 ,    NUM_CORES  $end
$var parameter 32 -    MEM_DEPTH  $end
$var wire      1 .    clk  $end
$var wire      1 /    rstn  $end
$var reg       2 0    rr_ptr [1:0] $end
$upscope $end


$scope module u_chk $end
$var parameter 32 1    NUM_CORES  $end
