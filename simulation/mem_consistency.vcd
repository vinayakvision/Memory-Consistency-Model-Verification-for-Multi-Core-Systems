$var reg      32 9    viol_got [31:0] $end
$var reg       4 :    viol_core [3:0] $end
$var reg       4 ;    log_ptr [3:0] $end
$upscope $end


$scope begin unmblk1 $end
$var reg      32 <    rd [31:0] $end
$upscope $end

$upscope $end

